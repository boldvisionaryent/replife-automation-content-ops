COMPOSE_PROJECT_NAME=replife_matomo
TZ=America/New_York

# Verify image tags on install day before production:
# docker manifest inspect matomo:5.10.0-apache
# docker manifest inspect mariadb:11.4-ubi
MATOMO_IMAGE_REF=matomo:5.10.0-apache
MARIADB_IMAGE_REF=mariadb:11.4-ubi

MATOMO_DB_NAME=matomo
MATOMO_DB_USER=matomo
MATOMO_DB_PASSWORD=replace_with_long_random_matomo_db_password
MATOMO_DB_ROOT_PASSWORD=replace_with_long_random_matomo_root_password
