DOMAIN=YOURDOMAIN.com
TZ=America/New_York

# AI automation only
GITHUB_TOKEN=replace_me
GITHUB_MODELS_MODEL=REPLACE_WITH_VERIFIED_GITHUB_MODELS_MODEL_ID
GITHUB_MODELS_INFERENCE_API_VERSION=2026-03-10
GITHUB_MODELS_CATALOG_API_VERSION=2026-03-10
AI_PAID_USAGE_ENABLED=no
AI_MONTHLY_BUDGET_USD=10
AI_DAILY_REQUEST_LIMIT=25
AI_WEEKLY_REQUEST_LIMIT=100

# Notifications and monitoring
DISCORD_WEBHOOK_URL=replace_me
BETTERSTACK_DEFAULT_HEARTBEAT_URL=replace_me
BETTERSTACK_MATOMO_ARCHIVE_HEARTBEAT_URL=replace_me_optional
BETTERSTACK_MATOMO_CONTENT_REPORT_HEARTBEAT_URL=replace_me_optional
BETTERSTACK_WEEKLY_REPORT_HEARTBEAT_URL=replace_me_optional
BETTERSTACK_WEEKLY_CONTENT_OPS_HEARTBEAT_URL=replace_me_optional
BETTERSTACK_MONTHLY_MAINTENANCE_HEARTBEAT_URL=replace_me_optional
BETTERSTACK_ONEDRIVE_MEDIA_ARCHIVE_HEARTBEAT_URL=replace_me_optional
BETTERSTACK_ONEDRIVE_RESTIC_BACKUP_HEARTBEAT_URL=replace_me_optional
BETTERSTACK_ONEDRIVE_ZIP_BACKUP_HEARTBEAT_URL=replace_me_optional
BETTERSTACK_ONEDRIVE_RESTORE_TEST_HEARTBEAT_URL=replace_me_optional

# Microsoft OneDrive archive and backup
RCLONE_ONEDRIVE_REMOTE=onedrive-replife
ONEDRIVE_ROOT_FOLDER=RepLife-VPS
RESTIC_ONEDRIVE_REPOSITORY=rclone:onedrive-replife:RepLife-VPS/resticbackups
RESTIC_PASSWORD_FILE=/home/YOUR_USER/replife-backend/secrets/restic-onedrive-password

# Matomo content analytics only
MATOMO_BASE_URL=https://analytics.YOURDOMAIN.com
MATOMO_SITE_ID=1
MATOMO_TOKEN=replace_me_optional

# Optional Postiz API loader, social scheduling only
POSTIZ_BASE_URL=https://social.YOURDOMAIN.com
POSTIZ_API_KEY=replace_me_optional
POSTIZ_API_BASE_PATH=/api/public/v1
POSTIZ_API_ENABLED=no
POSTIZ_DEFAULT_TIMEZONE=America/New_York
POSTIZ_ALLOWED_PLATFORMS=facebook,instagram,instagramstandalone,youtube,tiktok,linkedin,linkedin-page,x,reddit,medium
POSTIZ_MEDIA_UPLOAD_METHOD=api
POSTIZ_CLI_COMMAND=postiz
POSTIZ_CLI_UPLOAD_COMMAND=upload
POSTIZ_API_HOURLY_LIMIT=30
POSTIZ_API_SAFE_HOURLY_LIMIT=24
POSTIZ_MAX_APPROVED_ROWS_PER_RUN=6

# No commerce credentials belong in this file.