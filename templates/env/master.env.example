# RepLife Automation VPS master environment example
# Copy only the values needed for a specific service or script into that
service's private .env file.
# Never put real secrets in this example file.

# Domain and service URLs
ROOT_DOMAIN=example.com
MATOMO_URL=https://analytics.example.com
N8N_URL=https://automations.example.com
POSTIZ_URL=https://social.example.com
UPTIME_KUMA_URL=https://monitor.example.com
LOBEHUB_URL=https://ai.example.com

# AI provider settings for scripts
AI_PROVIDER=github_models
GITHUB_MODELS_TOKEN=REPLACE_WITH_PRIVATE_TOKEN_IN_REAL_ENV_ONLY
GITHUB_MODELS_MODEL=REPLACE_WITH_INSTALL_DAY_VERIFIED_MODEL
OPENROUTER_API_KEY=OPTIONAL_LOBEHUB_ONLY_DO_NOT_USE_FOR_REQUIRED_SCRIPTS
AI_MONTHLY_BUDGET_USD=10
AI_DAILY_REQUEST_LIMIT=100

# Postiz supervised API settings
POSTIZ_API_BASE_URL=https://social.example.com
POSTIZ_API_KEY=REPLACE_WITH_PRIVATE_POSTIZ_KEY_IN_REAL_ENV_ONLY
POSTIZ_API_ENABLED=no
POSTIZ_MAX_APPROVED_ROWS_PER_RUN=6
POSTIZ_API_HOURLY_CALL_LIMIT=30

# Matomo public content analytics only
MATOMO_SITE_ID=1
MATOMO_API_TOKEN=REPLACE_WITH_PRIVATE_TOKEN_IN_REAL_ENV_ONLY

# Better Stack heartbeat URLs
BETTERSTACK_WEEKLY_RUNNER_HEARTBEAT=
BETTERSTACK_BACKUP_HEARTBEAT=
BETTERSTACK_MATOMO_ARCHIVE_HEARTBEAT=

# OneDrive/rclone/restic backup settings
RCLONE_REMOTE_NAME=onedrive
RESTIC_REPOSITORY=rclone:onedrive:RepLife-VPS-Backups/restic
RESTIC_PASSWORD=REPLACE_WITH_PRIVATE_PASSWORD_IN_REAL_ENV_ONLY

# Local folder defaults
REPLIFE_BASE_DIR=/home/YOUR_USER/replife-backend
INPUT_MEDIA_DIR=/home/YOUR_USER/replife-backend/inputs/media
OUTPUT_DIR=/home/YOUR_USER/replife-backend/outputs
LOG_DIR=/home/YOUR_USER/replife-backend/logs

# Manual social metrics import files
SOCIAL_METRICS_IMPORT_CSV=/home/YOUR_USER/replifebackend/
inputs/social/manual_social_metrics.csv
SOCIAL_METRICS_EXPORT_CHECKLIST=/home/YOUR_USER/replifebackend/
docs/manual_social_metrics_export_checklist.md

# Product Prompting safety
PRODUCT_PROMPT_PUBLIC_SOCIAL_DEFAULT=no
PRODUCT_PROMPT_BLOCKED_PUBLIC_WORDS=buy,order,sale,discount,coupon,shippin
g,refund,return,checkout,available now,limited time,fulfillment,customer
support,track your order

# Never create these on the VPS
# WORDPRESS_APPLICATION_PASSWORD=
# WOOCOMMERCE_CONSUMER_KEY=
# WOOCOMMERCE_CONSUMER_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# GELATO_API_KEY=

